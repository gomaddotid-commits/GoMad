APP_NAME="GoMad"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://web.gomad.test

API_URL=http://api.gomad.test
LANDING_URL=http://gomad.test
SESSION_DOMAIN=.gomad.test
SANCTUM_STATEFUL_DOMAINS=web.gomad.test,localhost:8000

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

# Midtrans Configuration
MIDTRANS_SERVER_KEY=Mid-server-your-server-key
MIDTRANS_CLIENT_KEY=Mid-client-your-client-key
MIDTRANS_MERCHANT_ID=M089267701
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# FCM Configuration
FCM_SERVER_KEY=your-fcm-server-key

# Twilio Configuration (WhatsApp)
TWILIO_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Commission
COMMISSION_RATE=5
WARUNG_COMMISSION_RATE=2

# Withdrawal
MINIMAL_WITHDRAWAL=100000
WITHDRAWAL_ADMIN_FEE=5000
AUTO_APPROVE_LIMIT=5000000

# Support
SUPPORT_PHONE=081234567890
SUPPORT_EMAIL=support@gomad.id

# Mobile App
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=id.gomad.app
APP_STORE_URL=https://apps.apple.com/id/app/gomad/id123456789