APP_NAME="GoMad"
APP_ENV=production
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-app-url.onrender.com

DB_CONNECTION=mysql
DB_HOST=your-db-host.aivencloud.com
DB_PORT=your-db-port
DB_DATABASE=your-db-name
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_OPTIONS={"sslmode":"require"}

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

FCM_SERVER_KEY=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
GOOGLE_MAPS_API_KEY=

COMMISSION_RATE=5
WARUNG_COMMISSION_RATE=2
MINIMAL_WITHDRAWAL=100000
WITHDRAWAL_ADMIN_FEE=5000
AUTO_APPROVE_LIMIT=5000000
SUPPORT_PHONE=081234567890
SUPPORT_EMAIL=support@gomad.id
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=id.gomad.app
APP_STORE_URL=https://apps.apple.com/id/app/gomad/id123456789